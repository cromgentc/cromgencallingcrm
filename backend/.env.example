PORT=5000
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.mongodb.net/calltrack
# MONGO_URI is also supported if your project already uses that name.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=7d
ADMIN_NAME=Super Admin
ADMIN_EMAIL=admin@calltrack.local
ADMIN_PASSWORD=admin12345
ADMIN_SETUP_KEY=optional_setup_key_for_admin_register_api
SEED_ADMIN=false

# Email Marketing SMTP
# Gmail example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=yourgmail@gmail.com
# SMTP_PASS=your_16_character_gmail_app_password
# SMTP_FROM_EMAIL=yourgmail@gmail.com
# SMTP_FROM_NAME=CromGen CRM
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_EMAIL=yourgmail@gmail.com
SMTP_FROM_NAME=CromGen CRM

# Asterisk PBX / Edesy SIP integration
ASTERISK_AMI_HOST=127.0.0.1
ASTERISK_AMI_PORT=5038
ASTERISK_AMI_USER=crmami
ASTERISK_AMI_SECRET=change_this_ami_secret
ASTERISK_AMI_TIMEOUT_MS=10000
ASTERISK_ORIGINATE_CONTEXT=crm-outbound
ASTERISK_ORIGINATE_TIMEOUT_MS=30000
ASTERISK_CALLER_ID=CromGen CRM
