{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/[...path].js": {
      "includeFiles": "backend/**"
    },
    "api/auth/login.js": {
      "includeFiles": "backend/**"
    },
    "api/dashboard.js": {
      "includeFiles": "backend/**"
    },
    "api/health.js": {
      "includeFiles": "backend/**"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
