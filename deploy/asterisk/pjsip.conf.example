; Copy into /etc/asterisk/pjsip.conf and replace all CHANGE_ME values.
; Keep SIP credentials private.

[global]
type=global
user_agent=CromGenCRM-Asterisk

[transport-udp]
type=transport
protocol=udp
bind=0.0.0.0:5060
external_media_address=CHANGE_ME_PUBLIC_SERVER_IP
external_signaling_address=CHANGE_ME_PUBLIC_SERVER_IP
local_net=CHANGE_ME_PRIVATE_NETWORK_CIDR

; ===== Edesy SIP trunk =====
[edesy-auth]
type=auth
auth_type=userpass
username=CHANGE_ME_EDESY_SIP_USERNAME
password=CHANGE_ME_EDESY_SIP_PASSWORD

[edesy-aor]
type=aor
contact=sip:CHANGE_ME_EDESY_SIP_HOST:5060
qualify_frequency=60

[edesy-trunk]
type=endpoint
transport=transport-udp
context=from-edesy
disallow=all
allow=ulaw,alaw
outbound_auth=edesy-auth
aors=edesy-aor
from_user=CHANGE_ME_EDESY_SIP_USERNAME
from_domain=CHANGE_ME_EDESY_SIP_HOST
direct_media=no
rtp_symmetric=yes
force_rport=yes
rewrite_contact=yes

[edesy-identify]
type=identify
endpoint=edesy-trunk
match=CHANGE_ME_EDESY_SIP_HOST

; ===== Agent SIP phone template =====
[agent-template](!)
type=endpoint
transport=transport-udp
context=from-agent
disallow=all
allow=ulaw,alaw
direct_media=no
rtp_symmetric=yes
force_rport=yes
rewrite_contact=yes

[1001](agent-template)
auth=1001-auth
aors=1001-aor
callerid=Agent 1001 <1001>

[1001-auth]
type=auth
auth_type=userpass
username=1001
password=CHANGE_ME_STRONG_AGENT_PASSWORD

[1001-aor]
type=aor
max_contacts=1
remove_existing=yes
