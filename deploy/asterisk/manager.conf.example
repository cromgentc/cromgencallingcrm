; Copy into /etc/asterisk/manager.conf
; Restrict AMI to localhost/private CRM server only.

[general]
enabled = yes
port = 5038
bindaddr = 127.0.0.1

[crmami]
secret = CHANGE_ME_STRONG_AMI_SECRET
deny = 0.0.0.0/0.0.0.0
permit = 127.0.0.1/255.255.255.255
read = system,call,command,agent,user,originate
write = system,call,command,agent,user,originate
